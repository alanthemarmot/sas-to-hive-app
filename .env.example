# Copy this file to .env and fill in the values.
# The server loads .env from the workspace root.

# Required: GitHub fine-grained PAT for the GitHub Models API
GITHUB_PAT=your_github_pat_here

# Optional: Express server port (default: 3001)
# Feature worktrees use 3011–3017
PORT=3001

# Optional: Vite dev server port (default: 5173)
# Feature worktrees use 5181–5187
VITE_PORT=5173

# Optional: Hive JDBC URL — if unset, execution returns mock results
# HIVE_JDBC_URL=jdbc:hive2://localhost:10000/default
